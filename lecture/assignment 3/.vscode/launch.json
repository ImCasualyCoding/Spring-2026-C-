{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [
    "-fdiagnostics-color=always",
    "-g",
    "${fileDirname}/*.cpp", // This tells it to grab all .cpp files in the folder
    "-o",
    "${fileDirname}/${fileBasenameNoExtension}.exe"
],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "c:/coding/my work of art/spring2026/c++ systems/lecture/assignment 3",
      "program": "c:/coding/my work of art/spring2026/c++ systems/lecture/assignment 3/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}